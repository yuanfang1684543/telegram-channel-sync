# Telegram 频道同步机器人 - 环境变量配置示例
# 复制本文件为 .env 并填入真实值（本地运行）
# Railway / Render 等平台请在 Variables 面板中直接填写

# ═══════════════════════════════════════
#  必填项
# ═══════════════════════════════════════

# Telegram Bot Token — 从 @BotFather 获取
# 格式: 123456789:ABCDEFGHIjklmnopqrstuvwxyz_1234567890
BOT_TOKEN=123456789:ABCDEFGHIjklmnopqrstuvwxyz_1234567890

# ═══════════════════════════════════════
#  频道配置（二选一）
# ═══════════════════════════════════════

# 方式一：单频道映射（最简单）
# 源频道 ID（监听的频道，格式: -1001234567890）
SOURCE_CHANNEL_ID=-1001234567890
# 目标频道 ID（转发到的频道，格式: -1009876543210）
TARGET_CHANNEL_ID=-1009876543210

# 方式二：多频道映射（JSON 格式，与方式一互斥）
# CHANNEL_MAPPINGS_JSON='{"源频道id":"目标频道id","-1001111111111":"-1002222222222"}'

# ═══════════════════════════════════════
#  管理员（可选）
# ═══════════════════════════════════════

# 管理员用户 ID，多个用逗号分隔（不设则首次 /start 的用户自动成为管理员）
# ADMIN_IDS=123456789,987654321

# ═══════════════════════════════════════
#  存储路径（可选，默认当前目录）
# ═══════════════════════════════════════

# 配置文件路径
# CONFIG_PATH=config.json

# 消息 ID 映射文件路径（用于编辑同步）
# MSG_MAP_PATH=msg_map.json

# ═══════════════════════════════════════
#  Google Drive 备份（可选）
# ═══════════════════════════════════════

# Google 服务账号 JSON（整个 JSON 内容，不是文件路径）
# 获取方式: Google Cloud Console → IAM → 服务账号 → 创建密钥 → JSON
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...",...}

# ═══════════════════════════════════════
#  Gmail 邮件通知（可选）
# ═══════════════════════════════════════

# Gmail 发件账号
# GMAIL_USER=your-bot@gmail.com

# Gmail 应用专用密码（不是登录密码）
# 获取方式: Google 账号 → 安全性 → 两步验证 → 应用专用密码
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ═══════════════════════════════════════
#  注意事项
# ═══════════════════════════════════════
# 1. 不要将 .env 文件提交到 Git（已在 .gitignore 中排除）
# 2. 所有频道 ID 必须以 -100 开头
# 3. 机器人需要在频道中拥有管理员权限（发送消息权限）
# 4. Google 服务账号需要对目标 Drive 文件夹有写入权限
