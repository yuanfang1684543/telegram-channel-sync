# Telegram 频道同步机器人 - 环境变量配置示例
# 复制本文件为 .env 并填入真实值

# ========== 必填项 ==========

# Telegram Bot Token - 从 @BotFather 获取
# 格式: 123456789:ABCDEFGHIjklmnopqrstuvwxyz_1234567890
BOT_TOKEN=123456789:ABCDEFGHIjklmnopqrstuvwxyz_1234567890

# 源频道 ID - 要监听的频道
# 格式: -1001234567890 (必须以 -100 开头)
SOURCE_CHANNEL_ID=-1001234567890

# 目标频道 ID - 转发目标频道
# 格式: -1009876543210 (必须以 -100 开头)
TARGET_CHANNEL_ID=-1009876543210

# ========== 可选项（高级版本） ==========

# 多频道映射 (仅在使用 main_advanced.py 时生效)
# 格式: JSON 字符串
# 示例: '{"源频道id":"目标频道id","源频道id2":"目标频道id2"}'
# CHANNEL_MAPPINGS_JSON='{}' 

# ========== 注意事项 ==========
# 1. 不要提交此文件到 Git
# 2. Railway 中应在 Variables 中设置这些值
# 3. 所有频道 ID 必须以 -100 开头
# 4. Bot Token 需妥善保管，避免泄露
